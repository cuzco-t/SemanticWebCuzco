@prefix : <http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#> .

<http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#compran
:compran rdf:type owl:ObjectProperty ;
         owl:inverseOf :esVendidoA .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#destino
:destino rdf:type owl:ObjectProperty ;
         rdfs:domain :PaqueteTuristico ;
         rdfs:range :DestinoTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#esVendidoA
:esVendidoA rdf:type owl:ObjectProperty ;
            rdfs:domain :PaqueteTuristico ;
            rdfs:range :Turista .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#genero
:genero rdf:type owl:ObjectProperty ;
        rdfs:domain :Turista ;
        rdfs:range :Genero .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ofrece
:ofrece rdf:type owl:ObjectProperty ;
        owl:inverseOf :ofrecidoPor .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ofreceActividad
:ofreceActividad rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :ofrece ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :Alojamiento
                                             :PaqueteTuristico
                                             :Ubicacion
                                           )
                             ] ;
                 rdfs:range :Actividad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ofreceHospedaje
:ofreceHospedaje rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :ofrece ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( :PaqueteTuristico
                                             :Ubicacion
                                           )
                             ] ;
                 rdfs:range :Alojamiento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ofreceTransporte
:ofreceTransporte rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :ofrece ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :PaqueteTuristico
                                              :Ubicacion
                                            )
                              ] ;
                  rdfs:range :Transporte .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ofrecidoPor
:ofrecidoPor rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tiene
:tiene rdf:type owl:ObjectProperty ;
       owl:inverseOf :ubicadoEn .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneDescuento
:tieneDescuento rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :PaqueteTuristico
                                            :Turista
                                          )
                            ] ;
                rdfs:range :Descuento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ubicadoEn
:ubicadoEn rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :Alojamiento
                                       :DestinoTuristico
                                       :Ubicacion
                                     )
                       ] ;
           rdfs:range :Ubicacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ubicadoEnCiudad
:ubicadoEnCiudad rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :ubicadoEn ;
                 rdfs:range :Ciudad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ubicadoEnMontaña
:ubicadoEnMontaña rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :ubicadoEn ;
                  rdfs:range :Montaña .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ubicadoEnPlaya
:ubicadoEnPlaya rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :ubicadoEn ;
                rdfs:range :Playa .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#vende
:vende rdf:type owl:ObjectProperty ;
       owl:inverseOf :vendidoPor ;
       rdfs:domain :AgenciaDeTurismo ;
       rdfs:range :PaqueteTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#vendidoPor
:vendidoPor rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#viajaCon
:viajaCon rdf:type owl:ObjectProperty ,
                   owl:SymmetricProperty ;
          rdfs:domain :Turista ;
          rdfs:range :Turista .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#capacidad
:capacidad rdf:type owl:DatatypeProperty ;
           rdfs:domain :Transporte ;
           rdfs:range xsd:int .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#edad
:edad rdf:type owl:DatatypeProperty ;
      rdfs:domain :Turista ;
      rdfs:range xsd:int .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#precio
:precio rdf:type owl:DatatypeProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( :Alojamiento
                                    :Glamping
                                    :Hotel
                                    :PaqueteCultural
                                    :PaqueteDeEntretenimiento
                                    :PaqueteDeportivo
                                  )
                    ] ;
        rdfs:range xsd:double .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#precioPaquete
:precioPaquete rdf:type owl:DatatypeProperty ;
               rdfs:domain :PaqueteTuristico ;
               rdfs:range xsd:double .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneAeropuerto
:tieneAeropuerto rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :tieneEstacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneDesc
:tieneDesc rdf:type owl:DatatypeProperty ;
           rdfs:domain :Turista ;
           rdfs:range xsd:boolean .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneEstacion
:tieneEstacion rdf:type owl:DatatypeProperty ;
               rdfs:domain :Ubicacion ;
               rdfs:range xsd:boolean .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneEstacionTren
:tieneEstacionTren rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf :tieneEstacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneFecha
:tieneFecha rdf:type owl:DatatypeProperty ;
            rdfs:domain :PaqueteTuristico ;
            rdfs:range xsd:dateTime .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneNombre
:tieneNombre rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( :Actividad
                                         :AgenciaDeTurismo
                                         :Alojamiento
                                         :Turista
                                         :Ubicacion
                                       )
                         ] ;
             rdfs:range xsd:string .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tienePuerto
:tienePuerto rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :tieneEstacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#tieneTerminal
:tieneTerminal rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :tieneEstacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#vendidoEnElMes
:vendidoEnElMes rdf:type owl:DatatypeProperty ;
                rdfs:domain :PaqueteTuristico ;
                rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Actividad
:Actividad rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ActividadesCulturales
:ActividadesCulturales rdf:type owl:Class ;
                       rdfs:subClassOf :Actividad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ActividadesDeEntretenimiento
:ActividadesDeEntretenimiento rdf:type owl:Class ;
                              rdfs:subClassOf :Actividad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ActividadesDeportivas
:ActividadesDeportivas rdf:type owl:Class ;
                       rdfs:subClassOf :Actividad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#AgenciaDeTurismo
:AgenciaDeTurismo rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Alojamiento
:Alojamiento rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Autobus
:Autobus rdf:type owl:Class ;
         rdfs:subClassOf :Transporte .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Avion
:Avion rdf:type owl:Class ;
       rdfs:subClassOf :Transporte .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Ciudad
:Ciudad rdf:type owl:Class ;
        rdfs:subClassOf :Ubicacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescNiños
:DescNiños rdf:type owl:Class ;
           rdfs:subClassOf :Descuento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescPorTemporada
:DescPorTemporada rdf:type owl:Class ;
                  rdfs:subClassOf :Descuento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescTerceraEdad
:DescTerceraEdad rdf:type owl:Class ;
                 rdfs:subClassOf :Descuento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Descuento
:Descuento rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DestinoCultural
:DestinoCultural rdf:type owl:Class ;
                 rdfs:subClassOf :DestinoTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DestinoDeEntretenimiento
:DestinoDeEntretenimiento rdf:type owl:Class ;
                          rdfs:subClassOf :DestinoTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DestinoDeportivo
:DestinoDeportivo rdf:type owl:Class ;
                  rdfs:subClassOf :DestinoTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DestinoTuristico
:DestinoTuristico rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Femenino
:Femenino rdf:type owl:Class ;
          rdfs:subClassOf :Genero .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Genero
:Genero rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Glamping
:Glamping rdf:type owl:Class ;
          rdfs:subClassOf :Alojamiento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Hotel
:Hotel rdf:type owl:Class ;
       rdfs:subClassOf :Alojamiento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#HotelDeLujo
:HotelDeLujo rdf:type owl:Class ;
             rdfs:subClassOf :Hotel .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#HotelEconomico
:HotelEconomico rdf:type owl:Class ;
                rdfs:subClassOf :Hotel .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Lancha
:Lancha rdf:type owl:Class ;
        rdfs:subClassOf :Transporte .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Masculino
:Masculino rdf:type owl:Class ;
           rdfs:subClassOf :Genero .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Montaña
:Montaña rdf:type owl:Class ;
         rdfs:subClassOf :Ubicacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#PaqueteCultural
:PaqueteCultural rdf:type owl:Class ;
                 rdfs:subClassOf :PaqueteTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#PaqueteDeEntretenimiento
:PaqueteDeEntretenimiento rdf:type owl:Class ;
                          rdfs:subClassOf :PaqueteTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#PaqueteDeportivo
:PaqueteDeportivo rdf:type owl:Class ;
                  rdfs:subClassOf :PaqueteTuristico .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#PaqueteTuristico
:PaqueteTuristico rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Playa
:Playa rdf:type owl:Class ;
       rdfs:subClassOf :Ubicacion .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Resort
:Resort rdf:type owl:Class ;
        rdfs:subClassOf :Alojamiento .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Transporte
:Transporte rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Tren
:Tren rdf:type owl:Class ;
      rdfs:subClassOf :Transporte .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Turista
:Turista rdf:type owl:Class .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#TuristaAdulto
:TuristaAdulto rdf:type owl:Class ;
               rdfs:subClassOf :TuristaMayorDeEdad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#TuristaAdultoMayor
:TuristaAdultoMayor rdf:type owl:Class ;
                    rdfs:subClassOf :TuristaMayorDeEdad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#TuristaMayorDeEdad
:TuristaMayorDeEdad rdf:type owl:Class ;
                    rdfs:subClassOf :Turista .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#TuristaMenorDeEdad
:TuristaMenorDeEdad rdf:type owl:Class ;
                    rdfs:subClassOf :Turista .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Ubicacion
:Ubicacion rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescNiños
:DescNiños rdf:type owl:NamedIndividual ,
                    :DescNiños .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescPorTemporada
:DescPorTemporada rdf:type owl:NamedIndividual ,
                           :DescPorTemporada .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#DescTerceraEdad
:DescTerceraEdad rdf:type owl:NamedIndividual ,
                          :DescTerceraEdad .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Femenino
:Femenino rdf:type owl:NamedIndividual ,
                   :Femenino .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#Masculino
:Masculino rdf:type owl:NamedIndividual ,
                    :Masculino .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadCultural1
:actividadCultural1 rdf:type owl:NamedIndividual ,
                             :ActividadesCulturales ;
                    :tieneNombre "Visitar museos y galerías de arte" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadCultural2
:actividadCultural2 rdf:type owl:NamedIndividual ,
                             :ActividadesCulturales ;
                    :tieneNombre "Recorrer sitios históricos" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadCultural3
:actividadCultural3 rdf:type owl:NamedIndividual ,
                             :ActividadesCulturales ;
                    :tieneNombre "Probar la comida local" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeEntretenimiento1
:actividadDeEntretenimiento1 rdf:type owl:NamedIndividual ,
                                      :ActividadesDeEntretenimiento ;
                             :tieneNombre "Parques temáticos y atracciones" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeEntretenimiento2
:actividadDeEntretenimiento2 rdf:type owl:NamedIndividual ,
                                      :ActividadesDeEntretenimiento ;
                             :tieneNombre "Discotecas y vida nocturna" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeEntretenimiento3
:actividadDeEntretenimiento3 rdf:type owl:NamedIndividual ,
                                      :ActividadesDeEntretenimiento ;
                             :tieneNombre "Espectáculos en vivo" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeportiva1
:actividadDeportiva1 rdf:type owl:NamedIndividual ,
                              :ActividadesDeportivas ;
                     :tieneNombre "Senderismo y Trekking" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeportiva2
:actividadDeportiva2 rdf:type owl:NamedIndividual ,
                              :ActividadesDeportivas ;
                     :tieneNombre "Deportes acuáticos" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#actividadDeportiva3
:actividadDeportiva3 rdf:type owl:NamedIndividual ,
                              :ActividadesDeportivas ;
                     :tieneNombre "Deportes de equipo o individuales" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#agencia1
:agencia1 rdf:type owl:NamedIndividual ;
          :vende :paqueteTuristico1 ;
          :tieneNombre "SolCaribe" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#agencia2
:agencia2 rdf:type owl:NamedIndividual ;
          :vende :paqueteTuristico2 ;
          :tieneNombre "Travel Time Ecuador" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#agencia3
:agencia3 rdf:type owl:NamedIndividual ;
          :vende :paqueteTuristico3 ;
          :tieneNombre "Cite Tour" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#autobus
:autobus rdf:type owl:NamedIndividual ;
         :capacidad 25 .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#avion
:avion rdf:type owl:NamedIndividual ;
       :capacidad 130 .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#barco
:barco rdf:type owl:NamedIndividual ;
       :capacidad 67 .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ciudad1
:ciudad1 rdf:type owl:NamedIndividual ;
         :tieneAeropuerto "true"^^xsd:boolean ;
         :tieneNombre "Cuenca" ;
         :tieneTerminal "true"^^xsd:boolean .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ciudad2
:ciudad2 rdf:type owl:NamedIndividual ;
         :tieneAeropuerto "true"^^xsd:boolean ;
         :tieneNombre "Quito" ;
         :tieneTerminal "true"^^xsd:boolean .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#ciudad3
:ciudad3 rdf:type owl:NamedIndividual ;
         :tieneEstacionTren "true"^^xsd:boolean ;
         :tieneNombre "Alausi" ;
         :tieneTerminal "true"^^xsd:boolean .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#destinoTuristico1
:destinoTuristico1 rdf:type owl:NamedIndividual ;
                   :ofreceActividad :actividadCultural1 ,
                                    :actividadCultural2 ,
                                    :actividadCultural3 ;
                   :ubicadoEnCiudad :ciudad1 ;
                   :tieneNombre "Museo Pumapungo" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#destinoTuristico10
:destinoTuristico10 rdf:type owl:NamedIndividual ;
                    :ofreceActividad :actividadDeEntretenimiento1 ,
                                     :actividadDeEntretenimiento3 ,
                                     :actividadDeportiva2 ;
                    :ubicadoEnPlaya :playa1 ;
                    :tieneNombre "Playa" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#destinoTuristico11
:destinoTuristico11 rdf:type owl:NamedIndividual ;
                    :ofreceActividad :actividadDeportiva1 ,
                                     :actividadDeportiva3 ;
                    :ubicadoEnMontaña :montaña2 ;
                    :tieneNombre "Montaña" .


###  http://www.semanticweb.org/mcall/ontologies/2024/0/untitled-ontology-60#destinoTuristico12
:destinoTuristico12 rdf:type owl:NamedIndividual ;
                    :ofreceActividad :actividadDeportiva2 ,
                                     :actividadDeportiva3 ;
                    :ubicadoEnMontaña :montaña1 ;
                    :tieneNombre "Pesca Deportiva" .


